APP_NAME=Telecom Intelligence Platform API
APP_ENV=dev
APP_DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=5000

DATABASE_URL=postgresql+psycopg://telecom:telecom@db:5432/telecom_db
JWT_SECRET=change_me_to_a_very_long_random_secret_key_12345
JWT_EXPIRES_IN=1d
AUTH_COOKIE_NAME=telecom_access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:3000
